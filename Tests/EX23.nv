print("\n=== TEST 23: FUNCTIONS ===")

fun add(a, b) {
    return a + b
}

fun greet(name) {
    print("Hello,", name)
}

fun factorial(n) {
    if (n <= 1) {
        return 1
    }
    return n * factorial(n - 1)
}
fun fib(n){
    if(n==0) { return 1 }
    if(n==1) { return 1 }
    return fib(n-1)+fib(n-2)
}
  
print("add(5, 3) =", add(5, 3))
greet("Nova")
print("factorial(5) =", factorial(5))
print("Fib(10)=",fib(10))